% Repbar3 Configuration — hyperbeam-permabrain Forge Device Package
%
% PermaBrain consensus and query as a HyperBEAM Forge device package.
% This produces a composable `hyperbeam-permabrain` distro that can be
% loaded into any HyperBEAM node.
%
% Build:
%   rebar3 device package
%   rebar3 device test
%   rebar3 device publish --key wallet.json

{erl_opts, [debug_info]}.

{deps, [
  {hb, {git, "https://github.com/permaweb/HyperBEAM.git", {branch, "edge"}}}
]}.

{relx, [
  {release, {hyperbeam_permabrain, "0.1.0"}, [
    hyperbeam_permabrain
  ]},
  {vm_args, "config/vm.args"},
  {sys_config, "config/sys.config"},
  {extended_start_script, true}
]}.

{plugins, [
  {rebar3_device, {git, "https://github.com/permaweb/HyperBEAM.git", {branch, "edge"}}}
]}.