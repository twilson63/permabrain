{
  "name": "permabrain",
  "version": "0.2.0",
  "type": "module",
  "description": "Public signed third brain knowledge graph on Arweave/HyperBEAM. Importable by other agents.",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./api": "./src/agent-api.mjs",
    "./crypto": "./src/crypto.mjs",
    "./article": "./src/article.mjs",
    "./attestation": "./src/attestation.mjs",
    "./consensus": "./src/consensus.mjs",
    "./config": "./src/config.mjs",
    "./keys": "./src/keys.mjs",
    "./tags": "./src/tags.mjs",
    "./dataitem": "./src/dataitem.mjs"
  },
  "bin": {
    "permabrain": "./scripts/cli.mjs"
  },
  "scripts": {
    "test": "node test/test.mjs && node test/multi-agent.mjs && node test/crypto.mjs && node test/module-import.mjs && node test/pi-skill.mjs",
    "test:unit": "node test/test.mjs",
    "test:multi-agent": "node test/multi-agent.mjs",
    "test:module-import": "node test/module-import.mjs",
    "test:pi-skill": "node test/pi-skill.mjs",
    "test:hyperbeam": "node test/hyperbeam.mjs",
    "test:hb-reference": "node test/hb-reference.mjs",
  "test:hb-transport": "node test/hb-transport.mjs",
    "test:wikipedia": "node test/wikipedia.mjs",
    "test:arweave": "node test/arweave.mjs",
    "test:public-upload": "node test/public-upload.mjs"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "arweave": "^1.15.7"
  }
}